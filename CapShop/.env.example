# Keep this value identical to the SA password used by your existing SQL Server volume.
# If you want to rotate it, update the running container and recreate the volume only if needed.
SQL_SA_PASSWORD=ChangeMe_SQL_Password_123!

JwtSettings__SecretKey=ChangeMe_JWT_Secret_Key_AtLeast32Chars!!
JwtSettings__Issuer=CapShop.AuthService
JwtSettings__Audience=CapShop.Client

AUTH_SMTP_EMAIL=change-me@example.com
AUTH_SMTP_PASSWORD=change-me
AUTH_SMTP_HOST=smtp.gmail.com
AUTH_SMTP_PORT=587

NOTIFICATION_SMTP_EMAIL=change-me@example.com
NOTIFICATION_SMTP_PASSWORD=change-me
NOTIFICATION_SMTP_HOST=smtp.gmail.com
NOTIFICATION_SMTP_PORT=587

# AI Chatbot (Ollama RAG Service)
# Ollama must be running on the host machine.
# On Linux Docker: http://host.docker.internal:11434/api/generate (host-gateway is set automatically)
# On Mac/Windows Docker Desktop: http://host.docker.internal:11434/api/generate
# For local dev (no Docker): http://127.0.0.1:11434/api/generate
OLLAMA_URL=http://host.docker.internal:11434/api/generate
OLLAMA_MODEL=llama3.2:1b