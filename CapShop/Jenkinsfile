def runCommand(String unixCommand, String windowsCommand = null) {
    if (isUnix()) {
        sh unixCommand
    } else {
        bat(windowsCommand ?: unixCommand)
    }
}

pipeline {
    agent any

    environment {
        SQL_SA_PASSWORD    = credentials('capshop-sql-sa-password')
        AUTH_SMTP_EMAIL    = credentials('capshop-smtp-email')
        AUTH_SMTP_PASSWORD = credentials('capshop-smtp-password')
        AUTH_SMTP_HOST     = 'smtp.gmail.com'
        AUTH_SMTP_PORT     = '587'
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        // ─────────────────────────────────────────────────────────────────
        stage('Checkout') {
            steps { checkout scm }
        }

        // ─────────────────────────────────────────────────────────────────
        stage('Backend Tests') {
            steps {
                script {
                    def testProjects = [
                        'tests/CapShop.AuthService.Tests/CapShop.AuthService.Tests.csproj',
                        'tests/CapShop.CatalogService.Tests/CapShop.CatalogService.Tests.csproj',
                        'tests/CapShop.OrderService.Tests/CapShop.OrderService.Tests.csproj',
                        'tests/CapShop.AdminService.Tests/CapShop.AdminService.Tests.csproj'
                    ]
                    for (project in testProjects) {
                        runCommand(
                            "dotnet test ${project} --configuration Release",
                            "dotnet test ${project} --configuration Release"
                        )
                    }
                }
            }
        }

        // ─────────────────────────────────────────────────────────────────
        stage('Frontend Build') {
            steps {
                dir('frontend') {
                    script {
                        runCommand('npm ci', 'npm ci')
                        runCommand('npm run build', 'npm run build')
                    }
                }
            }
        }

        // ─────────────────────────────────────────────────────────────────
        // Local smoke test — optional, only if Docker is on the Jenkins agent
        stage('Local Smoke Test') {
            when { not { branch 'main' } }
            steps {
                script {
                    try {
                        runCommand('docker compose up -d --build', 'docker compose up -d --build')
                        sleep(time: 60, unit: 'SECONDS')
                        runCommand(
                            'curl --fail http://localhost:5000/gateway/admin/health',
                            'powershell -Command "Invoke-WebRequest -UseBasicParsing http://localhost:5000/gateway/admin/health"'
                        )
                    } finally {
                        runCommand('docker compose down', 'docker compose down')
                    }
                }
            }
        }

        // ─────────────────────────────────────────────────────────────────
        // SSH Deploy to Azure VM — runs on main branch only
        stage('Deploy to Azure VM') {
            when { branch 'main' }
            steps {
                script {
                    // Requires Jenkins credential: azure-vm-ssh-key (SSH private key)
                    // and azure-vm-ip (secret text with VM IP address)
                    withCredentials([
                        string(credentialsId: 'azure-vm-ip',       variable: 'VM_IP'),
                        string(credentialsId: 'azure-vm-username',  variable: 'VM_USER'),
                        sshUserPrivateKey(
                            credentialsId: 'azure-vm-ssh-key',
                            keyFileVariable: 'VM_KEY'
                        )
                    ]) {
                        runCommand("""
                            ssh -i \$VM_KEY \
                                -o StrictHostKeyChecking=no \
                                -o ConnectTimeout=30 \
                                \$VM_USER@\$VM_IP \
                                '/opt/redeploy.sh'
                        """)
                    }
                }
            }
        }
    }

    post {
        success { echo "✅ Pipeline succeeded!" }
        failure { echo "❌ Pipeline failed — check logs above." }
    }
}
